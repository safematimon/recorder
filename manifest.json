{
  "manifest_version": 3,
  "name": "Robot Framework Auto-Recorder",
  "version": "1.0",
  "description": "บันทึกการกระทำบนเว็บและสร้างเป็นไฟล์ Robot Framework",
  "permissions": ["storage", "activeTab", "scripting", "downloads"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Robot Recorder"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
